# DATA — Dashboard for Analytical Thought and Action
# Copy this file to `.env` and fill in what you use. Everything is optional.

# ── Security ──────────────────────────────────────────────────
# Shared secret for the bridge API. Leave empty for localhost-only use.
# If set, every API request must send X-Data-Token: <value> or ?key=<value>.
DATA_BRIDGE_TOKEN=

# ── Lifecycle ─────────────────────────────────────────────────
# auto   = bridge shuts down when the browser tab closes (default)
# daemon = bridge keeps running without a browser
DATA_LIFECYCLE_MODE=auto

# ── Port ──────────────────────────────────────────────────────
DATA_PORT=7777
